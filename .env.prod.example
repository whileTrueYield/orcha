# ============================================================================
# Orcha — production environment configuration
# ============================================================================
#
# Copy this file to .env.prod (which is gitignored) before running `make prod`.
#
# Unlike the dev .env, every value here MUST be set — there are no safe
# defaults for production. Items marked [GENERATE] require you to create a
# unique secret; items marked [CONFIGURE] depend on your infrastructure.
#
# docker-compose.prod.yaml reads variables with the __DOCKER_ prefix from
# this file and maps them into each service's runtime environment, same
# convention as the dev setup.
#
# ============================================================================


# --- Domain & TLS ---------------------------------------------------------
# [CONFIGURE] The single domain Traefik will serve (e.g. orcha.example.com).
# A DNS A record must point this domain to the server running Orcha.

ORCHA_DOMAIN=orcha.example.com

# [CONFIGURE] Email for Let's Encrypt certificate notifications.
LETS_ENCRYPT_EMAIL=admin@example.com


# --- Service ports --------------------------------------------------------
# Internal container ports — not exposed to the host (Traefik handles ingress).
# These defaults match the application code and rarely need changing.

__DOCKER_ORCHA_BACKEND_PORT=4000
__DOCKER_ORCHA_SUPPORT_PORT=3001
__DOCKER_ORCHA_AI_PORT=8000


# --- Postgres -------------------------------------------------------------
# [GENERATE] Use strong, unique values. The database is only reachable inside
# the Docker network, but credentials should still be non-trivial.
#
# Generate a password: openssl rand -base64 24

__DOCKER_POSTGRES_USER=orcha
__DOCKER_POSTGRES_DB=orcha
__DOCKER_POSTGRES_PASSWORD=CHANGE_ME


# --- Redis ----------------------------------------------------------------

__DOCKER_REDIS_HOSTNAME=redis
__DOCKER_REDIS_PORT=6379


# --- Session secret -------------------------------------------------------
# [GENERATE] Encrypts session cookies. Must be a strong random string.
#
# Generate: openssl rand -base64 32

__DOCKER_ORCHA_SESSION_SECRET=CHANGE_ME


# --- VAPID push notification keys ----------------------------------------
# [GENERATE] Required for browser push notifications.
#
# Generate: cd backend && npx web-push generate-vapid-keys --json

__DOCKER_VAPID_PUBLIC_KEY=CHANGE_ME
__DOCKER_VAPID_PRIVATE_KEY=CHANGE_ME


# --- MinIO (S3-compatible object storage) ---------------------------------
# [GENERATE] MinIO runs inside the Docker network. Use a strong password.
#
# Generate a password: openssl rand -base64 24

MINIO_ROOT_USER=orcha
MINIO_ROOT_PASSWORD=CHANGE_ME

__DOCKER_UPLOADS_BUCKET=orcha-uploads
__DOCKER_DOCS_BUCKET=orcha-docs


# --- Email provider -------------------------------------------------------
# [CONFIGURE] Uncomment ONE of the two options below and fill in the values.
# Email is required for user invitations, password resets, and notifications.

# Option A: SMTP
# __DOCKER_SMTP_HOST=smtp.example.com
# __DOCKER_SMTP_PORT=587
# __DOCKER_SMTP_USER=your-smtp-user
# __DOCKER_SMTP_PASS=your-smtp-password

# Option B: Resend (https://resend.com)
# __DOCKER_RESEND_API_KEY=re_xxxxxxxxxxxx
