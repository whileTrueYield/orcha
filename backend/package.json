  "scripts": {
    "prebuild": "prisma generate && prisma migrate deploy",
    "find-deadcode": "ts-prune",
    "build": "tsc",
    "dev:build": "dotenv -e .env.development -- yarn tsc",
    "dev:generate": "dotenv -e .env.development -- yarn prisma generate",
    "dev:db:reset": "dotenv -e .env.development -- yarn prisma migrate reset",
    "dev:db:push": "dotenv -e .env.development -- yarn prisma db push",
    "dev:db:deploy": "dotenv -e .env.development -- yarn prisma migrate deploy",
    "dev:db:migrate": "dotenv -e .env.development -- yarn prisma migrate dev",
    "dev:mock": "dotenv -e .env.development -- ts-node ./src/mocker/index.ts",
    "dev:demo": "dotenv -e .env.development -- ts-node ./src/mocker/demo/index.ts",
    "dev:start": "dotenv -e .env.development -- nodemon src/server.ts",
    "dev:hocuspocus": "dotenv -e .env.development -- nodemon src/hocuspocus/server.ts",
    "dev:cron": "dotenv -e .env.development -- nodemon src/cron.ts",
    "start": "nodemon src/server.ts",
    "cron": "nodemon src/cron.ts",
    "types": "graphql-codegen --config codegen.yml",
    "test:db:reset": "dotenv -e .env.test -- prisma migrate reset",
    "test:db:deploy": "dotenv -e .env.test -- prisma migrate deploy",
    "test:db:push": "dotenv -e .env.test -- prisma db push",
    "test": "dotenv -e .env.test -- nyc mocha --exit",
    "test:one": "dotenv -e .env.test -- mocha --exit",
    "test:debug": "dotenv -e .env.test -- mocha inspect",
    "studio": "dotenv -e .env.development -- yarn prisma studio",
    "doc:style": "tailwindcss -i ./templates/input.css -o ./templates/css/style.css",
    "script:MigrateTicketToTiptap": "dotenv -e .env.development -- ts-node ./src/scripts/MigrateTicketToTiptap.ts",
    "script:getDemoEmails": "dotenv -e .env.development -- ts-node ./src/scripts/getDemoEmails.ts",
    "experimental:closeTasks": "ts-node --transpile-only ./src/models/schedule/jobs/closeScheduleItems.ts"
  },
  "nyc": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "**/__tests__/**"
    ],
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "all": true
  },
