DATABASE_URL="postgresql://webapp:postgres@localhost:5432/tests?connection_limit=5"
NODE_ENV=test
VAPID_PUBLIC_KEY=vapid-public-key
VAPID_PRIVATE_KEY=vapid-private-key
ORCHA_HOSTNAME=localhost