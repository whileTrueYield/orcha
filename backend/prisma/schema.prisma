enum TicketStatus {
  UNSCHEDULED
  SCHEDULED
  DONE
  CANCELLED
}

model Ticket {
  // required fields
  id       Int    @id @default(autoincrement())
  title    String @db.VarChar
  progress Float  @default(0.0)
  estimate Int    @default(3600)

  // This represent the ID of the ticket within its product
  localId    Int?
  milestone  Boolean @default(false)
  estimating Boolean @default(false)

  // timestamps
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  eta         DateTime? @db.Timestamptz(6)
  closedAt    DateTime? @db.Timestamptz(6)
  scheduledAt DateTime? @db.Timestamptz(6)
  archivedAt  DateTime? @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  // enums
  status TicketStatus @default(UNSCHEDULED)
  stage  ModelStage   @default(DRAFT)

  // optional fields
  description String? @db.VarChar
  difficulty  Int?
  closingNote String? @db.VarChar
  foreignId   String? @db.VarChar

  // We do not want to expose indexableContent, this is solely for search
  indexableContent String @default("") @db.VarChar

  // relations
  authorId       Int?
  author         Role?        @relation("TicketAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  ownerId        Int?
  owner          Role?        @relation("TicketOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  productId      Int?
  product        Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  workflowId     Int?
  workflow       Workflow?    @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  folderId       Int?
  folder         Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  projectId      Int
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ancestors  Ticket[] @relation("TicketAncestry")
  successors Ticket[] @relation("TicketAncestry")

  // Supersession lineage (ADR 0010): when a worked Ticket's workflow changes it
  // is closed (CANCELLED) and the effort continues on a new linked Ticket.
  // `supersededById` points the original at its successor; `supersedes` is the
  // reverse list (the successor's originals). This is "this became that" — it is
  // deliberately NOT `ancestors`/`successors` (the dependency DAG the scheduler
  // reads), so lineage never injects phantom dependencies into scheduling.
  // onDelete: SetNull keeps a successor deletable without taking its original.
  supersededById Int?
  supersededBy   Ticket?  @relation("TicketSupersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes     Ticket[] @relation("TicketSupersession")

  ticketText             TicketText?
  ticketTextRevisions    TicketTextRevision[]
  comments               Comment[]
  questions              Question[]
  tags                   Tag[]
  watchers               Role[]                @relation("WatchedTicket")
  personalTags           PersonalTag[]
  features               Feature[]
  ticketWorkflowStates   TicketWorkflowState[]
  scheduleItems          ScheduleItem[]
  scheduleConfigs        ScheduleConfig[]
  cases                  Issue[]
  reportQueries          ReportQuery[]         @relation("primaryTicketFilter")
  reportSecondaryQueries ReportQuery[]         @relation("secondaryTicketFilter")

  // indices, table map and constraints
  @@unique([localId, productId])
  @@index([authorId])
  @@index([ownerId])
  @@index([productId])
  @@index([workflowId])
  @@index([folderId])
  @@index([organizationId])
  @@index([supersededById])
  @@index([stage])
  @@index([status])
  @@index([estimating])
  @@index([localId])
  @@index([foreignId])
  @@index([closedAt])
  @@index([eta])
  @@map("ticket")
}

model TicketText {
  // required fields
  id Int @id @default(autoincrement())

  ticketId Int    @unique
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Markdown source of truth + optimistic-concurrency version (ADR 0007); past
  // versions live in TicketTextRevision for stale-save merge base recovery.
  markdown String @default("")
  version  Int    @default(0)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

// Append-only Markdown history per saved version; see DocumentationPageTextRevision.
model TicketTextRevision {
  id Int @id @default(autoincrement())

  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  version  Int
  markdown String

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([ticketId, version])
  @@map("ticket_text_revision")
}

