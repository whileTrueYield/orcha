  @@index([ticketWorkflowStateId])
  @@index([fromTicketWorkflowStateId])
  @@index([authorId])
  @@map("ticket_workflow_state_note")
}

model TicketWorkflowState {
  // required fields
  id           Int     @id @default(autoincrement())
  name         String
  isActive     Boolean @default(true)
  isBlocked    Boolean @default(false)
  complete     Int     @default(0)
  todo         Int     @default(0)
  fractionable Boolean @default(false)
  position     Int     @default(0)

  // JSON fields
  checklist String @default("[]") @db.VarChar

  // Optional fields
  estimateMinimum    Int?
  estimateMostLikely Int?
  estimateMaximum    Int?
  estimate           DateTime? @db.Timestamptz(6)

  // relations
  assigneeId Int?
  assignee   Role?  @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  ticketId   Int
  ticket     Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // if we were to delete the workflow state, we still want to keep its copy
  // if this link is maintained we can then use it for statistical analysis
  workflowStateId Int?
  workflowState   WorkflowState? @relation(fields: [workflowStateId], references: [id], onDelete: SetNull)

  scheduleItems                ScheduleItem[]            @relation("ActiveWorkflowState")
  nextScheduleItems            ScheduleItem[]            @relation("NextWorkflowStates")
  ticketWorkflowStateNotes     TicketWorkflowStateNote[] @relation("ticketWorkflowState")
  fromTicketWorkflowStateNotes TicketWorkflowStateNote[] @relation("fromTicketWorkflowState")

  // indices, table map and constraints
  @@index([assigneeId])
  @@index([ticketId])
  @@index([workflowStateId])
  @@map("ticket_workflow_state")
}

