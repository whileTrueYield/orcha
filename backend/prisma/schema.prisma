generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

generator pothos {
  provider     = "prisma-pothos-types"
  clientOutput = "@prisma/client"
  output       = "../src/generated/pothos-types.ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PushSubscription {
  id             Int      @id @default(autoincrement())
  endpoint       String
  expirationTime String?
  JSONkeys       String
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  roleId Int
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([endpoint])
  @@index([roleId])
  @@map("push_subscription")
}

model Documentation {
  // required fields
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar
  description String?    @db.VarChar
  stage       ModelStage @default(DRAFT)
  logoUrl     String?    @db.VarChar

  // timestamps
  createdAt            DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @db.Timestamptz(6)
  lastPublishedAt      DateTime? @db.Timestamptz(6)
  lastPublishRequestAt DateTime? @db.Timestamptz(6)

  organizationId     Int
  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentationPages DocumentationPage[]    @relation()
  pois               DocumentationPagePOI[] @relation()

  @@index([organizationId])
  @@index([name])
  @@index([createdAt])
  @@map("documentation")
}

model DocumentationPage {
  // required fields
  id       Int     @id @default(autoincrement())
  title    String  @db.VarChar
  body     String  @db.VarChar
  position Int     @default(1)
  customId String? @db.VarChar // the uniq hashtag to reference this section

  // We do not want to expose indexableContent, this is solely for search
  indexableContent String @default("") @db.VarChar

  urls     String @default("[]") @db.VarChar // which URLs are assocatiated with this page
  keywords String @default("[]") @db.VarChar // which keywords are associated with this page

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organizationId        Int
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentationId       Int
  documentation         Documentation          @relation(fields: [documentationId], references: [id], onDelete: Cascade)
  parentId              Int?
  parent                DocumentationPage?     @relation("documentation_page_children", fields: [parentId], references: [id])
  children              DocumentationPage[]    @relation("documentation_page_children")
  pois                  DocumentationPagePOI[]
  documentationPageData DocumentationPageData?
  documentationPageText DocumentationPageText?
  documentationPageTextRevisions DocumentationPageTextRevision[]

  @@unique([documentationId, customId])
  @@index([organizationId])
  @@index([documentationId])
  @@index([parentId])
  @@map("documentation_page")
}

model DocumentationPageText {
  // required fields
  id Int @id @default(autoincrement())

  documentationPageId Int               @unique
  documentationPage   DocumentationPage @relation(fields: [documentationPageId], references: [id], onDelete: Cascade)

  // Markdown is the literal source of truth (ADR 0007). `version` is the
  // optimistic-concurrency counter, bumped on every successful save; past
  // versions live in DocumentationPageTextRevision so a stale save can recover
  // its base for 3-way merge.
  markdown String @default("")
  version  Int    @default(0)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

// Append-only history feeding the 3-way merge: one row per saved version,
// holding the exact Markdown at that version so `saveBody` can fetch the base a
// stale writer started from. See backend/src/markdown/bodyRepository.ts.
model DocumentationPageTextRevision {
  id Int @id @default(autoincrement())

  documentationPageId Int
  documentationPage   DocumentationPage @relation(fields: [documentationPageId], references: [id], onDelete: Cascade)

  version  Int
  markdown String

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([documentationPageId, version])
  @@map("documentation_page_text_revision")
}

model DocumentationPageData {
  // required fields
  id Int @id @default(autoincrement())

  documentationPageId Int               @unique
  documentationPage   DocumentationPage @relation(fields: [documentationPageId], references: [id], onDelete: Cascade)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("documentation_page_data")
}

// Documentation Point of Interrest is used to associate
// a documentation with a page
model DocumentationPagePOI {
  id Int @id @default(autoincrement())

  urls     String @db.VarChar // which URLs are assocatiated with this page
  keywords String @db.VarChar // which keywords are associated with this page
  title    String @db.VarChar
  hashtag  String @db.VarChar // the uniq hashtag to reference this section

  documentationId     Int
  documentation       Documentation     @relation(fields: [documentationId], references: [id], onDelete: Cascade)
  documentationPageId Int
  documentationPage   DocumentationPage @relation(fields: [documentationPageId], references: [id], onDelete: Cascade)

  @@unique([documentationId, hashtag])
  @@index([documentationId])
  @@index([documentationPageId])
  @@map("documentation_page_poi")
}

model Comment {
  // required fields
  id   Int    @id @default(autoincrement())
  body String @db.VarChar

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // relations
  authorId Int
  author   Role @relation(fields: [authorId], references: [id], onDelete: Cascade)

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  acceptedReplyId Int?
  acceptedReply   CommentReply? @relation("AcceptedCommentReply", fields: [acceptedReplyId], references: [id], onDelete: SetNull)

  replies CommentReply[] @relation("CommentReplies")

  // indices, table map and constraints
  @@index([authorId])
  @@index([organizationId])
  @@index([ticketId])
  @@index([acceptedReplyId])
  @@index([createdAt])
  @@map("comment")
}

model CommentReply {
  // required fields
  id   Int    @id @default(autoincrement())
  body String @db.VarChar

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // relations
  authorId Int
  author   Role @relation(fields: [authorId], references: [id], onDelete: Cascade)

  commentId Int
  comment   Comment @relation("CommentReplies", fields: [commentId], references: [id], onDelete: Cascade)

  Organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId Int?

  /// This should contain between 0 and 1 comment because of a
  /// qwirk of the relational mirroring logic of Prisma
  acceptedReplyForComments Comment[] @relation("AcceptedCommentReply")

  // indices, table map and constraints
  @@index([authorId])
  @@index([commentId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("comment_reply")
}

model Report {
  // required fields
  id    Int        @id @default(autoincrement())
  name  String     @db.VarChar
  stage ModelStage @default(DRAFT)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  reportQueries ReportQuery[]

  @@index([organizationId])
  @@index([name])
  @@index([createdAt])
  @@map("report")
}

enum ReportGroupBy {
  // following are relations
  PRODUCT
  WORKFLOW
  WORKFLOW_STATE
  TAG
  ASSIGNEE

  // following are dates
  CREATED_AT
  ETA
  CLOSED_AT
  SCHEDULED_AT
  WORK_DAY
}

enum ReportAggregateField {
  TICKET_COUNT
  SUM_HOURS_WORKED
}

enum ReportDateGranularity {
  AUTO
  DAY
  WEEK
  MONTH
}

enum ReportWidgetType {
  COMPARE_THROUGH_TIME
  VALUES_THROUGH_TIME
  VALUES_BROKEN_DOWN_NOW
  VALUES_NOW
  COMPARE_VALUES_NOW
  CALENDAR
}

model ReportQuery {
  id             Int                  @id @default(autoincrement())
  title          String
  position       Int                  @default(0)
  rows           Int                  @default(1)
  cols           Int                  @default(1)
  noUnknowns     Boolean              @default(true)
  cummulative    Boolean              @default(false)
  widgetType     ReportWidgetType
  aggregateField ReportAggregateField @default(TICKET_COUNT)

  // relations
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reportId       Int
  report         Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // date window is global and only relevant on cases where
  // the grouping is done using a date field or the metric
  // is the sum of hours worked
  fromDate    String?
  untilDate   String?
  granularity ReportDateGranularity @default(AUTO)

  // primary breakdown
  chartBy      ReportGroupBy  @default(PRODUCT)
  chartByLabel String?
  groupBy      ReportGroupBy?
  groupByLabel String?

  // primary filters for Tickets
  byTags                   Tag[]           @relation("primaryTagFilter")
  byProducts               Product[]       @relation("primaryProductFilter")
  byWorkflows              Workflow[]      @relation("primaryWorkflowFilter")
  byFeatures               Feature[]       @relation("primaryFeatureFilter")
  byTickets                Ticket[]        @relation("primaryTicketFilter")
  byOwners                 Role[]          @relation("primaryReportQueryOwners")
  byAuthors                Role[]          @relation("primaryReportQueryAuthors")
  byAssignees              Role[]          @relation("primaryReportQueryAssignees")
  byWorkflowStateAssignees Role[]          @relation("primaryReportQueryWorkflowStateAssignees")
  byWorkflowStates         WorkflowState[] @relation("primaryWorkflowStateFilter")

  // A JSON string to be parsed that represents list of folders
  byPaths String @default("[]") @db.VarChar

  // Schedule Item filters, these are actually ternaries, for example:
  // for isTicketDone:
  // - null means ignore this filter
  // - false means is not done
  // - true means is done
  isTicketDone       Boolean?
  isTicketActive     Boolean?
  isTicketStarted    Boolean?
  isTicketNotStarted Boolean?

  // optional secondary breakdown
  secondaryChartBy      ReportGroupBy?
  secondaryChartByLabel String?
  secondaryGroupBy      ReportGroupBy?
  secondaryGroupByLabel String?

  // use the primary filter instead of the one defined below
  sameAsPrimaryFilter Boolean @default(true)

  // secondary filters for Tickets
  secondaryByTags                   Tag[]           @relation("secondaryTagFilter")
  secondaryByProducts               Product[]       @relation("secondaryProductFilter")
  secondaryByWorkflows              Workflow[]      @relation("secondaryWorkflowFilter")
  secondaryByFeatures               Feature[]       @relation("secondaryFeatureFilter")
  secondaryByTickets                Ticket[]        @relation("secondaryTicketFilter")
  secondaryByOwners                 Role[]          @relation("secondaryReportQueryOwners")
  secondaryByAuthors                Role[]          @relation("secondaryReportQueryAuthors")
  secondaryByAssignees              Role[]          @relation("secondaryReportQueryAssignees")
  secondaryByWorkflowStateAssignees Role[]          @relation("secondaryReportQueryWorkflowStateAssignees")
  secondaryByWorkflowStates         WorkflowState[] @relation("secondaryWorkflowStateFilter")

  // Schedule Item filters, these are actually ternaries, for example:
  // for isTicketDone:
  // - null means ignore this filter
  // - false means is not done
  // - true means is done
  secondaryIsTicketDone       Boolean?
  secondaryIsTicketActive     Boolean?
  secondaryIsTicketStarted    Boolean?
  secondaryIsTicketNotStarted Boolean?

  // A JSON string to be parsed that represents list of folders
  secondaryByPaths String @default("[]") @db.VarChar

  // indices, table map and constraints
  @@index([organizationId])
  @@index([reportId])
  @@map("report_query")
}

model Todo {
  // required fields
  id      Int     @id @default(autoincrement())
  checked Boolean @default(false)
  body    String  @db.VarChar

  // timestamps
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  checkedAt DateTime? @db.Timestamptz(6)
  dueDate   DateTime? @db.Timestamptz(6)

  // relations
  ownerId        Int
  owner          Role         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // indices, table map and constraints
  @@index([organizationId])
  @@index([ownerId])
  @@index([createdAt])
  @@index([checkedAt])
  @@index([checked])
  @@map("todo")
}

enum NoteColor {
  YELLOW
  BLUE
  PURPLE
  GREEN
  PINK
  ORANGE
}

model Note {
  // required fields
  id    Int       @id @default(autoincrement())
  body  String    @db.VarChar
  color NoteColor @default(YELLOW)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // relations
  ownerId Int
  owner   Role @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // indices, table map and constraints
  @@index([ownerId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("note")
}

enum NotificationTarget {
  PROJECT
  TICKET
  QUESTION
  COMMENT
  REPLY
}

// When adding a new notification type, make sure you update the 
// desktop notifications definitions and behaviors on these files:
// - orcha-backend/src/notifications/endpoints.ts
// - orcha-frontend/public/script/notification-worker.js 
enum NotificationCategory {
  MENTION // when you're being mentioned
  REPLY // when someone replies
  OWNED // when someone owned the document
  WATCHED // when someone watch the document
  ACCEPTED_REPLY // when someone accepts your reply
  CLOSED_TICKET // when a ticket is closed
  READY_TO_SCHEDULE // when a ticket is ready to be scheduled 
}

model Notification {
  id       Int                  @id @default(autoincrement())
  isRead   Boolean              @default(false)
  title    String
  category NotificationCategory
  target   NotificationTarget
  targetId Int

  // optional
  description String?
  ancestry    String?

  // relations
  roleId Int
  role   Role @relation("NotificationRole", fields: [roleId], references: [id], onDelete: Cascade)

  // relations
  actorId Int
  actor   Role @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // indices, table map and constraints
  @@index([roleId])
  @@index([actorId])
  @@index([organizationId])
  @@index([target, targetId, category])
  @@index([createdAt])
  @@index([isRead])
  @@map("notification")
}

model EmailConfirmation {
  // required fields
  id     Int    @id @default(autoincrement())
  email  String @unique @db.VarChar
  secret String @db.VarChar

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // indices, table map and constraints
  @@index([email])
  @@map("email_confirmation")
}

model Feature {
  // required fields
  id   Int    @id @default(autoincrement())
  name String @db.VarChar

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // relations
  featureGroupId Int
  featureGroup   FeatureGroup @relation(fields: [featureGroupId], references: [id], onDelete: Cascade)

  skills                 Skill[]
  tickets                Ticket[]
  scheduleConfigs        ScheduleConfig[]
  pages                  Page[]
  reportQueries          ReportQuery[]    @relation("primaryFeatureFilter")
  reportSecondaryQueries ReportQuery[]    @relation("secondaryFeatureFilter")

  // indices, table map and constraints
  @@index([featureGroupId])
  @@map("feature")
}

enum FeatureGroupStatus {
  ACTIVE
  DEPRECATED
}

model FeatureGroup {
  // required fields
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar
  isActive Boolean @default(false) @db.Boolean

  // Optional fields
  description String? @db.VarChar

  // Enums
  status FeatureGroupStatus @default(ACTIVE)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // relations
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  features Feature[]

  // indices, table map and constraints
  @@index([organizationId])
  @@index([productId])
  @@map("feature_group")
}

model migrations {
  id        Int    @id @default(autoincrement())
  timestamp BigInt
  name      String @db.VarChar
}

model OrganizationAddress {
  // required and optional fields
  id       Int     @id @default(autoincrement())
  address1 String  @db.VarChar
  address2 String? @db.VarChar
  zipcode  String  @db.VarChar
  city     String  @db.VarChar
  state    String? @db.VarChar
  country  String  @db.VarChar

  // relations
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  mailingAddressFor Organization[] @relation("MailingAddress")
  billingAddressFor Organization[] @relation("BillingAddress")

  // indices, table map and constraints
  @@index([organizationId])
  @@map("organization_address")
}

enum IssueStatus {
  NEW
  PROCESSING
  RESOLVED
}

model Issue {
  id      Int @id @default(autoincrement())
  localId Int

  // relations
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticketId       Int?
  ticket         Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  productId      Int
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  assigneeId     Int?
  assignee       Role?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  unread         Boolean      @default(true)
  archived       Boolean      @default(false)

  email       String @db.VarChar
  name        String @db.VarChar
  url         String @db.VarChar
  metaData    String @db.VarChar
  description String @db.VarChar
  userAgent   String @db.VarChar
  token       String @unique @db.VarChar

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // if ticket is still open, mark it as resolved
  resolveAfterDate DateTime? @db.Timestamptz(6)

  // enums
  status IssueStatus @default(NEW)

  // relations
  issueActions IssueAction[]

  @@unique([localId, organizationId])
  // indices, table map and constraints
  @@index([organizationId])
  @@index([ticketId])
  @@index([productId])
  @@index([assigneeId])
  @@index([localId, organizationId])
  @@index([token])
  @@index([unread])
  @@index([resolveAfterDate, status])
  @@map("issue")
}

enum IssueActionCategory {
  CLIENT_MESSAGE
  SUPPORT_MESSAGE
  SUPPORT_NOTE
  CHANGE_STATUS
  SET_ASSIGNEE
  SET_TICKET
  AUTO_RESOLVED
  CLIENT_IMAGE
  SUPPORT_IMAGE
}

model IssueAction {
  id    Int     @id @default(autoincrement())
  title String  @db.VarChar
  body  String? @db.VarChar

  // enums
  category IssueActionCategory

  // relations
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  issueId        Int
  issue          Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId       Int?
  author         Role?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // indices, table map and constraints
  @@index([organizationId])
  @@index([issueId])
  @@index([authorId])
  @@map("issue_action")
}

enum OrganizationStatus {
  ACTIVE
  DELETED
  SUSPENDED
}

model FeatureFlag {
  id            Int     @id @default(autoincrement())
  documentation Boolean @default(false)
  support       Boolean @default(false)
  report        Boolean @default(false)

  organizationId Int          @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // indices, table map and constraints
  @@index([organizationId])
}

enum ScheduleStatus {
  OK
  BLOCKED // when a ticket is marked as blocked
  ASSIGNEE_DEACTIVATED // when at least one ticket has a deactivated assignee
}

model Organization {
  // required fields
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar

  // if there is a problem in the schedule, this flag should be set to true
  scheduleStatus ScheduleStatus @default(OK)

  preferences String @default("{}") @db.VarChar

  // Optional fields
  about    String? @db.VarChar
  coverUrl String? @db.VarChar

  // enums
  status OrganizationStatus @default(ACTIVE)

  // timestamps
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)
  estimatedAt DateTime @default(now())

  // relations
  mailingAddressId Int?
  mailingAddress   OrganizationAddress? @relation("MailingAddress", fields: [mailingAddressId], references: [id], onDelete: SetNull)
  billingAddressId Int?
  billingAddress   OrganizationAddress? @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  featureFlag      FeatureFlag?

  // relations
  addresses              OrganizationAddress[]
  commentReplies         CommentReply[]
  comments               Comment[]
  documentationPages     DocumentationPage[]
  documentations         Documentation[]
  featureGroups          FeatureGroup[]
  folders                Folder[]
  projects               Project[]
  issueActions           IssueAction[]
  notes                  Note[]
  notifications          Notification[]
  organizationUploads    OrganizationUpload[]
  pages                  Page[]
  personalTags           PersonalTag[]
  products               Product[]
  questionReplies        QuestionReply[]
  questions              Question[]
  reportQuery            ReportQuery[]
  reports                Report[]
  roles                  Role[]
  scheduleConfigs        ScheduleConfig[]
  scheduleItems          ScheduleItem[]
  skills                 Skill[]
  supportTickets         Issue[]
  tags                   Tag[]
  teams                  Team[]
  tickets                Ticket[]
  timeOffs               TimeOff[]
  todos                  Todo[]
  workflows              Workflow[]
  workflowStates         WorkflowState[]
  blackoutTimes          BlackoutTime[]
  recurringBlackoutTimes RecurringBlackoutTime[]
  drawings               Drawing[]
  personalAccessTokens   PersonalAccessToken[]
  oauthAuthorizationCodes OAuthAuthorizationCode[]
  oauthAccessTokens       OAuthAccessToken[]
  oauthRefreshTokens      OAuthRefreshToken[]

  // settings
  showOnboarding Boolean @default(true)

  // indices, table map and constraints
  @@index([estimatedAt])
  @@index([mailingAddressId])
  @@index([billingAddressId])
  @@map("organization")
}

model OrganizationUpload {
  // required fields
  id   Int    @id @default(autoincrement())
  path String @db.VarChar

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // relations
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         Int?
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  // indices, table map and constraints
  @@index([organizationId])
  @@index([roleId])
  @@map("organization_upload")
}

model PasswordLost {
  // required fields
  id     Int    @id @default(autoincrement())
  email  String @db.VarChar
  secret String @db.VarChar

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // indices, table map and constraints
  @@index([email])
  @@map("password_lost")
}

// A Personal Access Token (PAT) is a long-lived credential bound to a single
// Role — a User's membership in one Organization. Because it resolves to one
// Role, it carries both identity and tenant scope, so the existing
// organizationId tenant middleware enforces isolation with no extra logic.
//
// Only the SHA-256 hash and a short display prefix are stored; the plaintext
// is shown once at creation and is never recoverable afterward. A token may be
// read-only, may expire, and may be revoked.
model PersonalAccessToken {
  // required fields
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar
  tokenHash   String  @unique @db.VarChar
  tokenPrefix String  @db.VarChar
  readOnly    Boolean @default(false)

  // optional fields
  lastUsedAt DateTime? @db.Timestamptz(6)
  expiresAt  DateTime? @db.Timestamptz(6)
  revokedAt  DateTime? @db.Timestamptz(6)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // relations
  roleId         Int
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // indices, table map and constraints
  @@index([tokenHash])
  @@index([roleId])
  @@index([organizationId])
  @@map("personal_access_token")
}

// An OAuth 2.1 client registered via Dynamic Client Registration (DCR).
// Intentionally global (no organizationId): the org scope is carried by the
// grant (OAuthAuthorizationCode / OAuthAccessToken), not the client itself.
// Clients in this slice are public PKCE clients — no client secret is stored.
model OAuthClient {
  // required fields
  id               Int      @id @default(autoincrement())
  clientId         String   @unique @db.VarChar
  name             String?  @db.VarChar
  redirectUris     String[]
  clientIdIssuedAt DateTime @default(now()) @db.Timestamptz(6)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // inverse relations
  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]
  refreshTokens      OAuthRefreshToken[]

  // indices, table map and constraints
  @@index([clientId])
  @@map("oauth_client")
}

// A single-use, PKCE-S256-bound authorization code issued during the
// /authorize flow. `codeHash` is SHA-256(plaintext_code); the plaintext is
// handed to the client and never stored. `consumedAt` is set on first
// exchange; a non-null value means the code was already spent.
model OAuthAuthorizationCode {
  // required fields
  id            Int       @id @default(autoincrement())
  codeHash      String    @unique @db.VarChar
  codeChallenge String    @db.VarChar
  redirectUri   String    @db.VarChar
  scope         String    @db.VarChar
  expiresAt     DateTime  @db.Timestamptz(6)
  consumedAt    DateTime? @db.Timestamptz(6)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // relations
  clientId       Int
  client         OAuthClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  roleId         Int
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // indices, table map and constraints
  @@index([codeHash])
  @@map("oauth_authorization_code")
}

// A short-lived opaque access token issued after a successful PKCE exchange.
// `tokenHash` is SHA-256(plaintext_token); plaintext carries the `orcha_oat_`
// prefix and is shown once. `revokedAt` enables soft-revocation without
// deleting the row (useful for audit). `lastUsedAt` is the "last seen" signal
// the connected-apps view shows — verifyAndResolveOAuth stamps it on each
// successful resolve, so it stays null only until the token is first used.
model OAuthAccessToken {
  // required fields
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique @db.VarChar
  scope     String   @db.VarChar
  readOnly  Boolean  @default(false)
  // Groups one rotation chain; lets a reuse-triggered family revoke reach live
  // access tokens, not just refresh tokens. See OAuthRefreshToken. The DB-side
  // gen_random_uuid() default exists ONLY to backfill the pre-existing rows this
  // column is added to (so the migration is a single safe statement); application
  // code always sets familyId explicitly via mintAccessToken.
  familyId  String   @default(dbgenerated("gen_random_uuid()")) @db.VarChar
  expiresAt DateTime @db.Timestamptz(6)

  // optional fields
  revokedAt  DateTime? @db.Timestamptz(6)
  lastUsedAt DateTime? @db.Timestamptz(6)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // relations
  clientId       Int
  client         OAuthClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  roleId         Int
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // indices, table map and constraints
  @@index([tokenHash])
  @@index([familyId])
  @@index([roleId])
  @@index([organizationId])
  @@map("oauth_access_token")
}

// A long-lived, rotating refresh token. Exchanged at /token for a fresh access
// token AND a new refresh token; the old one is marked `rotatedAt` (spent).
// `tokenHash` is SHA-256(plaintext) with the `orcha_ort_` prefix; plaintext is
// shown once. `familyId` groups a rotation chain: reusing a spent token revokes
// the whole family (`revokedAt` across every live token sharing the id) — the
// OAuth 2.1 reuse-detection behavior. TTL is a sliding 30 days.
model OAuthRefreshToken {
  // required fields
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique @db.VarChar
  familyId  String   @db.VarChar
  scope     String   @db.VarChar
  readOnly  Boolean  @default(false)
  expiresAt DateTime @db.Timestamptz(6)

  // optional fields
  rotatedAt DateTime? @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)

  // timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // relations
  clientId       Int
  client         OAuthClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  roleId         Int
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // indices, table map and constraints
  @@index([tokenHash])
  // IDEA: revokeFamily filters (familyId, revokedAt: null); a composite
  // @@index([familyId, revokedAt]) here and on oauth_access_token would keep the
  // theft-path sweep index-only as rotation families grow. Single-column is fine
  // at current family sizes — deferred to avoid an extra migration now.
  @@index([familyId])
  @@map("oauth_refresh_token")
}

