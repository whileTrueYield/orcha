  authorId                  Int
  author                    Role                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  fromTicketWorkflowStateId Int
  fromTicketWorkflowState   TicketWorkflowState @relation("fromTicketWorkflowState", fields: [fromTicketWorkflowStateId], references: [id], onDelete: Cascade)

  // indices, table map and constraints
