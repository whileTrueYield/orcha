{
  "name": "orcha-frontend",
  "version": "0.1.0",
  "private": true,
  "volta": {
    "node": "22.11.0",
    "yarn": "1.22.22"
  },
  "type": "module",
  "dependencies": {
    "@apollo/client": "^3.9.9",
    "@excalidraw/excalidraw": "^0.16.0",
    "@headlessui/react": "1.7.18",
    "@heroicons/react": "^1.0.1",
    "@hookform/error-message": "^2.0.1",
    "@hookform/resolvers": "^3.10.0",
    "@milkdown/crepe": "^7.21.1",
    "@nivo/bar": "^0.85.1",
    "@nivo/bump": "^0.85.1",
    "@nivo/calendar": "^0.85.1",
    "@nivo/core": "^0.85.1",
    "@nivo/line": "^0.85.1",
    "@nivo/pie": "^0.85.1",
    "@nivo/sunburst": "^0.85.1",
    "@popperjs/core": "^2.11.8",
    "@reduxjs/toolkit": "^2.2.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.12",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.4.3",
    "@types/classnames": "^2.3.1",
    "@types/highlight.js": "^10.1.0",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.0",
    "@types/node": "^18.11.15",
    "@types/papaparse": "^5.3.14",
    "@types/prettier": "^2.7.3",
    "@types/randomcolor": "^0.5.7",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "5.3.3",
    "@types/redux-logger": "^3.0.13",
    "@types/yup": "^0.32.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "classnames": "^2.5.1",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.1",
    "fast-json-patch": "^3.1.1",
    "framer-motion": "^11.0.23",
    "fuzzysort": "^2.0.4",
    "global": "^4.4.0",
    "graphql": "^16.8.1",
    "highlight.js": "^11.9.0",
    "lodash": "^4.17.21",
    "lowlight": "^3.1.0",
    "papaparse": "^5.4.1",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.2.1",
    "randomcolor": "^0.6.2",
    "react": "^18.2.0",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.2",
    "react-popper": "^2.3.0",
    "react-redux": "^9.1.0",
    "react-router-dom": "5.3.4",
    "react-use-measure": "^2.1.1",
    "redux": "^5.0.1",
    "redux-logger": "^3.0.6",
    "remark-breaks": "^4.0.0",
    "remark-directive": "^4.0.0",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.3",
    "tippy.js": "^6.3.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "web-vitals": "^3.1.0",
    "yup": "^0.32.11"
  },
  "scripts": {
    "prestart": "yarn stamp-jsonp-rev && yarn stamp-local-rev",
    "find-deadcode": "ts-prune",
    "start": "vite",
    "prebuild": "yarn stamp-jsonp-rev && yarn stamp-local-rev",
    "stamp-jsonp-rev": "echo \"window.setOrchaRevision(\\\"sha:${IMAGE_TAG}\\\");\" > public/revision.js",
    "stamp-local-rev": "echo \"export const revision = \\\"sha:${IMAGE_TAG}\\\";\" > src/utils/revision.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "TZ=UTC jest",
    "e2e": "cypress open",
    "style": "npx tailwindcss -i src/index.css -o ./public/css/tailwind.css",
    "analyze": "source-map-explorer 'build/static/js/*.js' --html analyze-results.html",
    "find-unused-exports": "find-unused-exports"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "resolutions": {
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.3",
    "prosemirror-transform": "^1.10.5"
  },
  "jest": {
    "preset": "ts-jest/presets/js-with-ts",
    "testEnvironment": "jest-environment-jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js",
      "\\.(css|less)$": "<rootDir>/__mocks__/styleMock.js"
    },
    "modulePaths": [
      "<rootDir>/src"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.0.0-0",
    "@babel/plugin-syntax-flow": "^7.14.5",
    "@babel/plugin-transform-react-jsx": "^7.14.9",
    "@faker-js/faker": "^7.6.0",
    "@nivo/tooltip": "0.80.0",
    "@types/react-test-renderer": "^18.0.0",
    "buffer": "^6.0.3",
    "cypress": "^12.1.0",
    "find-unused-exports": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react-test-renderer": "^18.2.0",
    "ts-jest": "^29.1.2",
    "ts-prune": "^0.10.3"
  }
}
