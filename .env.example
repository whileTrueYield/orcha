# ============================================================================
# Orcha — environment configuration
# ============================================================================
#
# Copy this file to .env (which is gitignored) before running `make` for
# the first time. All values below are working defaults for local dev —
# no edits needed to get started.
#
# For production, regenerate the session secret, VAPID keys, and MinIO
# password. See the comments next to each value.
#
# docker-compose.yaml reads variables prefixed __DOCKER_ from this file and
# passes them into each service's runtime environment under their ORCHA_*
# names. The double-underscore prefix marks "host-level config" vs values
# the services read at runtime — keep that mental model.
#
# ============================================================================


# --- Service ports --------------------------------------------------------
# Defaults match the URLs you'll see referenced throughout the docs.

__DOCKER_ORCHA_BACKEND_PORT=4000
__DOCKER_ORCHA_FRONTEND_PORT=3000
__DOCKER_ORCHA_SUPPORT_PORT=3001
__DOCKER_ORCHA_AI_PORT=8000
__DOCKER_ORCHA_WWW_PORT=3002


# --- Postgres -------------------------------------------------------------
# Dev defaults; the database is local to the docker network and never
# exposed publicly, so the trivial password is fine for development.

__DOCKER_POSTGRES_USER=webapp
__DOCKER_POSTGRES_DB=webapp
__DOCKER_POSTGRES_PASSWORD=postgres


# --- Redis ----------------------------------------------------------------

__DOCKER_REDIS_HOSTNAME=redis
__DOCKER_REDIS_PORT=6379


# --- Session secret -------------------------------------------------------
# Encrypts session cookies. Fine for local dev; regenerate for production
# with: openssl rand -base64 32

__DOCKER_ORCHA_SESSION_SECRET=dev-session-secret-not-for-production


# --- VAPID push notification keys -----------------------------------------
# Required for browser push notifications. These are throwaway dev keys —
# regenerate for production with:
#
#   cd backend && npx web-push generate-vapid-keys --json

__DOCKER_VAPID_PUBLIC_KEY=BCJLUzKBQ-DLdZafnUxfDJw4o1TLMT24HkJ8jAsIRWA5SWTEIORl5emwbCtoM3s98lc01MheIid75rFNPQmUIIg
__DOCKER_VAPID_PRIVATE_KEY=00CFT4PyujlhxohVn2mqnvkT0YFT9OOSQkphDQgkZEE


# --- MinIO (local S3 emulation) -------------------------------------------
# MinIO provides S3-compatible object storage for file uploads and
# documentation publishing. Works out of the box — no AWS account needed.
#
# For production with real S3 or DO Spaces, set S3_ENDPOINT to the
# provider URL and S3_ACCESS_KEY / S3_SECRET_KEY to real credentials.
# Point UPLOADS_CDN_URL and DOCS_CDN_URL to your CDN distribution.

MINIO_ROOT_USER=orcha
MINIO_ROOT_PASSWORD=orchadev123

__DOCKER_UPLOADS_BUCKET=orcha-uploads
__DOCKER_DOCS_BUCKET=orcha-docs
__DOCKER_UPLOADS_CDN_URL=http://localhost:9000/orcha-uploads
__DOCKER_DOCS_CDN_URL=http://localhost:9000/orcha-docs


# --- E2E test interface ---------------------------------------------------

__DOCKER_ORCHA_TEST_INTERFACE=false
